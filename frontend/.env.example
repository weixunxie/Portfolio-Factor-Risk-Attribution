# ── Frontend environment variables ────────────────────────────────────────────
# Copy this file to .env.local for local development.
# On Vercel, set these in the Vercel project Settings → Environment Variables.
# NEVER add backend secrets (DATABASE_URL, OPENAI_API_KEY, etc.) here.

# URL of the FastAPI backend.
# Local development: leave as http://127.0.0.1:8000
# Production (Vercel): set to your Railway backend URL.
# Example: https://your-backend.up.railway.app
NEXT_PUBLIC_API_BASE_URL=http://127.0.0.1:8000
