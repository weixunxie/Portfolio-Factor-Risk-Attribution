# ── Backend environment variables ─────────────────────────────────────────────
# Copy this file to .env and fill in real values.
# NEVER commit .env — it is in .gitignore.

# ── Database (Supabase / PostgreSQL) ──────────────────────────────────────────
# Use the direct connection (port 5432) for local dev.
# Use the connection-pooler URL (port 6543) on Railway with NullPool.
DATABASE_URL=

# ── Qdrant vector store ───────────────────────────────────────────────────────
QDRANT_URL=
QDRANT_API_KEY=
QDRANT_COLLECTION_NAME=company_risk_documents

# ── Tiingo (PRIMARY market data — large free quota + adjusted close) ──────────
# Register free at https://www.tiingo.com → API → Token.
TIINGO_API_KEY=

# ── Alpha Vantage (fallback market data — free tier 25 calls/day) ─────────────
ALPHA_VANTAGE_API_KEY=

# ── SEC EDGAR (required by EDGAR fair-use policy) ────────────────────────────
SEC_USER_AGENT="Your Name your.email@example.com"

# ── OpenAI (AI risk summary) ─────────────────────────────────────────────────
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# ── CORS (Railway / Vercel) ───────────────────────────────────────────────────
# Set to your Vercel frontend URL, or * to allow all origins.
# Example: FRONTEND_ORIGIN=https://your-app.vercel.app
# For development, leave blank — localhost:3000/3002 are allowed by default.
FRONTEND_ORIGIN=
